{
  "name": "faircount",
  "version": "0.2.0",
  "description": "An honest estimate of how many distinct values a stream contains — the unbiased CVM variant, with proven (ε, δ) error bounds in flat memory. Stream, promise and core APIs.",
  "type": "module",
  "main": "./src/index.mjs",
  "module": "./src/index.mjs",
  "types": "./types/index.d.mts",
  "exports": {
    ".": {
      "types": "./types/index.d.mts",
      "import": "./src/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "types",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node --test",
    "test:watch": "node --test --watch",
    "lint": "standard",
    "lint:fix": "standard --fix",
    "bench": "node bench/index.mjs",
    "prepublishOnly": "npm run lint && npm test"
  },
  "keywords": [
    "cvm",
    "distinct",
    "count-distinct",
    "unique-count",
    "cardinality",
    "streaming",
    "stream",
    "sketch",
    "estimation",
    "estimator",
    "unbiased",
    "probabilistic",
    "hyperloglog"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mauro-d/faircount.git"
  },
  "homepage": "https://github.com/mauro-d/faircount#readme",
  "bugs": {
    "url": "https://github.com/mauro-d/faircount/issues"
  },
  "author": "Mauro <mauro.doganieri@gmail.com>",
  "license": "ISC",
  "devDependencies": {
    "standard": "^17.1.2"
  },
  "standard": {
    "ignore": [
      "types/"
    ]
  }
}
